  "texts": {
    "pt": {
      "title": "Santuário da Mãe Peregrina",
      "subtitle": "Fé e devoção no alto da Gameleira",
      "description": "O Santuário da Mãe Peregrina, em Nova Venécia, é um espaço de profunda espiritualidade e encontro com Deus. Nascido de relatos de aparições, reúne peregrinos em oração, trilha e contemplação, oferecendo uma experiência de fé, paz e renovação espiritual."
    },
    "en": {
      "title": "Shrine of the Pilgrim Mother",
      "subtitle": "Faith and devotion at the top of the Gameleira",
      "description": "The Shrine of the Pilgrim Mother, in Nova Venécia, is a space of deep spirituality and encounter with God. Born from accounts of apparitions, it brings together pilgrims in prayer, trail and contemplation, offering an experience of faith, peace and spiritual renewal."
    },
    "es": {
      "title": "Santuario de la Madre Peregrina",
      "subtitle": "Fe y devoción en la cima de la Gameleira",
      "description": "El Santuario de la Peregrina, en Nova Venécia, es un espacio de profunda espiritualidad y encuentro con Dios. Nacido de relatos de apariciones, reúne a los peregrinos en oración, sendero y contemplación, ofreciendo una experiencia de fe, paz y renovación espiritual."
    }
  },
